{
  "opencollection": "1.0.0",
  "info": {
    "name": "Optimizely Graph API",
    "version": "2.0"
  },
  "request": {
    "auth": {
      "type": "apikey",
      "key": "auth",
      "value": "{{auth}}",
      "placement": "query"
    }
  },
  "items": [
    {
      "info": {
        "name": "GraphQL",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Execute a GraphQL query via GET",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://cg.optimizely.com/content/v2",
            "params": [
              {
                "name": "auth",
                "value": "",
                "type": "query",
                "description": "Single key authentication token"
              },
              {
                "name": "query",
                "value": "",
                "type": "query",
                "description": "The GraphQL query string"
              },
              {
                "name": "variables",
                "value": "",
                "type": "query",
                "description": "JSON-encoded query variables"
              },
              {
                "name": "operationName",
                "value": "",
                "type": "query",
                "description": "Name of the operation to execute"
              }
            ]
          },
          "docs": "Sends a GraphQL query via GET request using query parameters. Useful for simple queries and caching scenarios."
        },
        {
          "info": {
            "name": "Execute a GraphQL query",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://cg.optimizely.com/content/v2",
            "params": [
              {
                "name": "auth",
                "value": "",
                "type": "query",
                "description": "Single key authentication token"
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Sends a GraphQL query to the Optimizely Graph service for content retrieval and search. The query is executed against the content model indexed in Optimizely Graph, enabling flexible data retrieval across all connected content sources."
        }
      ]
    }
  ],
  "bundled": true
}