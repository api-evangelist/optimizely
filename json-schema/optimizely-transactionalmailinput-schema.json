{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/TransactionalMailInput",
  "title": "TransactionalMailInput",
  "type": "object",
  "description": "Input for sending a transactional email",
  "required": [
    "recipient_email",
    "mailing_id"
  ],
  "properties": {
    "recipient_email": {
      "type": "string",
      "format": "email",
      "description": "Email address of the recipient"
    },
    "mailing_id": {
      "type": "integer",
      "format": "int64",
      "description": "Identifier for the transactional mailing template"
    },
    "personalization": {
      "type": "object",
      "description": "Key-value pairs for personalizing the email content",
      "additionalProperties": {
        "type": "string"
      }
    }
  }
}